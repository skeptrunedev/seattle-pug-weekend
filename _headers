# Always revalidate the app shell so deploys show up immediately (no stale CSS/JS).

/
  Cache-Control: no-cache

/index.html
  Cache-Control: no-cache

/style.css
  Cache-Control: no-cache

/app.js
  Cache-Control: no-cache

/sw.js
  Cache-Control: no-cache

/manifest.webmanifest
  Cache-Control: no-cache

# Art / icons can cache for a week.

/assets/*
  Cache-Control: public, max-age=604800

/icon-192.png
  Cache-Control: public, max-age=604800

/icon-512.png
  Cache-Control: public, max-age=604800

/apple-touch-icon.png
  Cache-Control: public, max-age=604800

/favicon.ico
  Cache-Control: public, max-age=604800
